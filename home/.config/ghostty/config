theme = Adwaita Dark
# theme = Gruvbox Dark          # warm amber/earth tones, a timeless classic
# theme = Gruvbox Material Dark # softer, more muted gruvbox variant
# theme = Everforest Dark Hard  # nature-inspired greens, easy on the eyes
# theme = Flexoki Dark          # warm ink-on-paper aesthetic
# theme = Iceberg Dark          # cool blue-grey, calm and focused
# theme = Atom One Dark         # clean dark from the Atom editor era
# theme = GitHub Dark Default   # clean modern dark, familiar if you use GitHub
# theme = Melange Dark          # cozy warm dark with great contrast
# theme = Zenbones Dark         # minimal, low-contrast, zen
# theme = Raycast Dark          # polished modern macOS-style dark
# theme = One Half Dark         # balanced, easy to read for long sessions
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms

